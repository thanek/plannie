# Publiczny host używany do budowania linku/QR do join.
# Może być sam host (np. planning.example.com) albo pełny URL (np. https://planning.example.com).
PORT=8000
RELOAD=true
PUBLIC_HOST=localhost
# Opcjonalny schemat dla PUBLIC_HOST bez protokołu (domyślnie: schemat requestu).
# PUBLIC_SCHEME=https
# Opcjonalny port dla PUBLIC_HOST bez portu (domyślnie: brak; dla localhost używa portu requestu).
# PUBLIC_PORT=8443

